#!/bin/bash

# Display a system power menu using rofi dmenu.

menu() {
  local prompt="$1"
  local options="$2"

  echo -e "$options" | rofi -dmenu -p "$prompt" -theme-str 'window { width: 295px; }' 2>/dev/null
}

options="  Lock"
options="$options\n󰒲  Suspend"
options="$options\n󰍃  Logout"
options="$options\n󰜉  Restart"
options="$options\n󰐥  Shutdown"

case $(menu "System" "$options") in
*Lock*) nafi-lock-screen ;;
*Suspend*) systemctl suspend ;;
*Logout*) loginctl terminate-user "$USER" ;;
*Restart*) systemctl reboot ;;
*Shutdown*) systemctl poweroff ;;
esac

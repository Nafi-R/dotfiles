#!/bin/bash

# Open the wallpaper picker in Walker via the nafiWallpaper Elephant module.

if ! pgrep -x elephant > /dev/null; then
  setsid uwsm-app -- elephant &
fi

if ! pgrep -f "walker --gapplication-service" > /dev/null; then
  setsid uwsm-app -- walker --gapplication-service &
fi

exec walker --width 644 --maxheight 300 --minheight 300 -m menus:nafiWallpaper
